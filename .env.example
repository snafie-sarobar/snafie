# ============================================
# APPLICATION CONFIGURATION
# ============================================
PORT=3000
NODE_ENV=development
APP_NAME=FullStack App
FRONTEND_URL=http://localhost:3000

# ============================================
# DATABASE - PostgreSQL
# ============================================
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=fullstack_app
DB_SSL=false

# ============================================
# CACHE - Redis
# ============================================
REDIS_URL=redis://localhost:6379

# ============================================
# AUTHENTICATION
# ============================================
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-2024
REFRESH_SECRET=your-refresh-secret-key-change-this-too-2024

# ============================================
# OPENAI / AI FEATURES
# ============================================
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4

# ============================================
# EMAIL (SMTP)
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# ============================================
# STRIPE PAYMENTS
# ============================================
STRIPE_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# ============================================
# FILE UPLOADS
# ============================================
MAX_FILE_SIZE=209715200
UPLOAD_DIR=./uploads

# ============================================
# MAPS - OpenStreetMap (free, no key needed)
# Or use Mapbox / Google Maps for advanced features
# ============================================
REACT_APP_MAPBOX_TOKEN=
REACT_APP_GOOGLE_MAPS_KEY=

# ============================================
# WEBRTC / VIDEO CALLING
# ============================================
REACT_APP_TURN_URL=turn:your-turn-server.com:3478
REACT_APP_TURN_USERNAME=your-turn-username
REACT_APP_TURN_CREDENTIAL=your-turn-credential

# ============================================
# RTMP / LIVE STREAMING
# ============================================
RTMP_HOST=localhost
RTMP_PORT=1935

# ============================================
# DOCKER
# ============================================
API_PORT=3000
WEB_PORT=8080

# ============================================
# AWS (optional - for cloud storage)
# ============================================
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=
